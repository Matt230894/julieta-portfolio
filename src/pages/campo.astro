---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Del campo" description="Notas, fotos y hallazgos desde el trabajo de campo en los Parques Nacionales de Corrientes">

  <div class="container page-content">

    <header class="page-header">
      <span class="page-label">Notas de campo</span>
      <h1>Del campo</h1>
      <p class="page-desc">
        Lo que pasa cuando estás adentro del ecosistema estudiándolo, no leyendo sobre él.
      </p>
    </header>

    {posts.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">📓</div>
        <h2>Las primeras notas llegan pronto</h2>
        <p>Estoy preparando el primer viaje de campo. Volvé en breve.</p>
        <a href="/apoyame" class="btn-primary">Apoyar el viaje →</a>
      </div>
    ) : (
      <div class="posts-list">
        {posts.map(post => (
          <article class="post-row">
            {post.data.cover && (
              <img src={post.data.cover} alt={post.data.title} class="post-thumb" />
            )}
            <div class="post-info">
              <time class="post-date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h2><a href={`/campo/${post.slug}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <div class="post-tags">
                {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

  </div>

</Layout>

<style>
.page-content {
  padding-top: 4rem;
  padding-bottom: 4rem;
}

.page-header {
  margin-bottom: 3rem;
  border-bottom: 2px solid var(--verde-oscuro);
  padding-bottom: 1.5rem;
}

.page-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--tierra);
  display: block;
  margin-bottom: 0.5rem;
}

.page-header h1 {
  font-size: 2.5rem;
  color: var(--verde-oscuro);
  margin-bottom: 0.5rem;
}

.page-desc {
  color: var(--humo);
  font-style: italic;
  font-size: 1rem;
}

.empty-state {
  text-align: center;
  padding: 5rem 2rem;
  background: var(--crema-oscura);
  border: 1px dashed var(--ceniza);
  border-radius: 4px;
}

.empty-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
}

.empty-state h2 {
  color: var(--verde-oscuro);
  margin-bottom: 0.75rem;
}

.empty-state p {
  color: var(--humo);
  margin-bottom: 1.5rem;
  font-style: italic;
}

.btn-primary {
  display: inline-block;
  background: var(--fuego);
  color: var(--crema);
  padding: 0.75em 1.8em;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  border-radius: 2px;
  transition: background 0.2s;
}
.btn-primary:hover {
  background: #e05520;
  color: var(--crema);
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.post-row {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 1.5rem;
  background: white;
  border: 1px solid var(--crema-oscura);
  border-radius: 3px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}

.post-row:hover {
  box-shadow: 0 4px 16px rgba(26,46,26,0.08);
}

.post-thumb {
  width: 200px;
  height: 140px;
  object-fit: cover;
}

.post-info {
  padding: 1.25rem 1.25rem 1.25rem 0;
}

.post-date {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--humo);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: block;
  margin-bottom: 0.4rem;
}

.post-info h2 {
  font-size: 1.2rem;
  margin-bottom: 0.5rem;
}

.post-info h2 a {
  color: var(--verde-oscuro);
}

.post-info h2 a:hover {
  color: var(--fuego);
}

.post-info p {
  font-size: 0.9rem;
  color: var(--humo);
  margin-bottom: 0.75rem;
}

.post-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

@media (max-width: 580px) {
  .post-row { grid-template-columns: 1fr; }
  .post-thumb { width: 100%; height: 180px; }
  .post-info { padding: 1rem; }
}
</style>
