---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>

  <article class="container post-page">

    <header class="post-header">
      <a href="/campo" class="back-link">← Volver al campo</a>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <div class="post-tags">
          {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <h1>{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
    </header>

    {post.data.cover && (
      <img src={post.data.cover} alt={post.data.title} class="post-cover" />
    )}

    <div class="post-content">
      <Content />
    </div>

    <!-- GALERÍA -->
    {post.data.gallery && post.data.gallery.length > 0 && (
      <div class="gallery-section">
        <h3 class="gallery-title">Fotos del campo</h3>
        <div class="gallery-grid">
          {post.data.gallery.map((item: any) => (
            <figure class="gallery-item">
              <a href={item.image} target="_blank" rel="noopener">
                <img src={item.image} alt={item.caption ?? 'Foto de campo'} />
              </a>
              {item.caption && <figcaption>{item.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </div>
    )}

    <footer class="post-footer">
      <div class="apoyo-inline">
        <p>Si esta investigación te parece valiosa, podés apoyarla.</p>
        <a href="https://cafecito.app/TUUSUARIO" target="_blank" rel="noopener" class="btn-cafecito">
          ☕ Invitame un cafecito
        </a>
        <a href="/apoyame" class="btn-mas">Otras formas →</a>
      </div>
      <a href="/campo" class="back-link">← Más entradas del campo</a>
    </footer>

  </article>

</Layout>

<style>
.post-page {
  padding-top: 3rem;
  padding-bottom: 5rem;
  max-width: 720px;
}

.back-link {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--tierra);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: inline-block;
  margin-bottom: 1.5rem;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.post-meta time {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--humo);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.post-tags {
  display: flex;
  gap: 0.4rem;
}

.post-header h1 {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: var(--verde-oscuro);
  margin-bottom: 0.75rem;
}

.post-desc {
  font-size: 1.1rem;
  color: var(--humo);
  font-style: italic;
  margin-bottom: 2rem;
}

.post-cover {
  width: 100%;
  max-height: 420px;
  object-fit: cover;
  border-radius: 3px;
  margin-bottom: 2.5rem;
}

/* Markdown content styling */
.post-content {
  font-size: 1.05rem;
  line-height: 1.85;
  color: #2a2a28;
}

.post-content h2 {
  font-size: 1.5rem;
  color: var(--verde-oscuro);
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
}

.post-content h3 {
  font-size: 1.2rem;
  color: var(--verde-medio);
  margin-top: 2rem;
  margin-bottom: 0.5rem;
}

.post-content p {
  margin-bottom: 1.25rem;
}

.post-content img {
  width: 100%;
  border-radius: 3px;
  margin: 1.5rem 0;
}

.post-content blockquote {
  border-left: 3px solid var(--verde-sage);
  padding-left: 1.25rem;
  color: var(--humo);
  font-style: italic;
  margin: 1.5rem 0;
}

.post-content strong {
  color: var(--carbon);
  font-weight: 700;
}

.post-content a {
  text-decoration: underline;
  text-underline-offset: 3px;
}

.gallery-section {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--crema-oscura);
}

.gallery-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--humo);
  margin-bottom: 1.25rem;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 0.75rem;
}

.gallery-item {
  margin: 0;
  overflow: hidden;
  border-radius: 3px;
  background: var(--crema-oscura);
}

.gallery-item a {
  display: block;
  overflow: hidden;
}

.gallery-item img {
  width: 100%;
  height: 160px;
  object-fit: cover;
  transition: transform 0.3s;
}

.gallery-item:hover img {
  transform: scale(1.04);
}

.gallery-item figcaption {
  padding: 0.5rem 0.6rem;
  font-size: 0.75rem;
  color: var(--humo);
  font-style: italic;
  line-height: 1.4;
}

/* Footer */
.post-footer {
  margin-top: 3.5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--crema-oscura);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.apoyo-inline {
  background: var(--crema-oscura);
  padding: 1.5rem;
  border-radius: 3px;
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.apoyo-inline p {
  flex: 1;
  font-style: italic;
  color: var(--humo);
  min-width: 180px;
  margin: 0;
}

.btn-cafecito {
  background: #f8b400;
  color: var(--carbon);
  padding: 0.5em 1.2em;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 2px;
  white-space: nowrap;
}
.btn-cafecito:hover { color: var(--carbon); }

.btn-mas {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--verde-claro);
  white-space: nowrap;
}
</style>
